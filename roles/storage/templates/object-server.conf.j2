[DEFAULT]
devices = /srv/node
bind_ip = {{ ansible_ens8.ipv4.address }}
bind_port = 6000
# bind_port = 8080
workers = 2

[pipeline:main]
pipeline = object-server

[app:object-server]
{% if swift_backend is defined and swift_backend == 'memory' %}
use = egg:swift#mem_object
{% else %}
use = egg:swift#object
{% endif %}

[object-replicator]

[object-updater]

[object-auditor]

[object-expirer]

[object-reconstructor]

[object-relinker]
