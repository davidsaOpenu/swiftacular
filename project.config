[access]
	inheritFrom = All-Projects
[submit]
[project]
	description = Deploy OpenStack Swift with Ansible and Vagrant
[access "refs/*"]
	owner = group user/davidsaOpenu
[access "refs/for/refs/*"]
	label-Code-Review = -2..+2 group user/Adrian Fusco (adrianfusco)
	label-Code-Review = -2..+2 group user/davidsaOpenu
	label-Verified = -1..+1 group user/davidsaOpenu
	push = group user/davidsaOpenu
	read = group user/davidsaOpenu
	rebase = group user/Adrian Fusco (adrianfusco)
	rebase = group user/davidsaOpenu
	removeReviewer = group user/Adrian Fusco (adrianfusco)
	removeReviewer = group user/davidsaOpenu
	submit = group user/Adrian Fusco (adrianfusco)
	submit = group user/davidsaOpenu
[access "refs/heads/*"]
	create = group user/davidsaOpenu
	push = +force group user/davidsaOpenu
	pushMerge = group user/davidsaOpenu
	read = group user/davidsaOpenu
[access "refs/tags/*"]
	push = group user/davidsaOpenu
	push = +force group user/davidsaOpenu
